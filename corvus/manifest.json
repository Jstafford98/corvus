{
  "manifest_version": 2,
  "name": "Corvus",
  "version": "1.0.0",
  "description": "AI browser assistant with tool use, skills, and browser control.",

  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "screenshots",
    "<all_urls>"
  ],

  "background": {
    "scripts": ["background/background.js"],
    "persistent": true
  },

  "sidebar_action": {
    "default_title": "Corvus",
    "default_panel": "sidebar/sidebar.html",
    "default_icon": "icons/corvus.svg"
  },

  "options_ui": {
    "page": "dashboard/dashboard.html",
    "open_in_tab": true
  },

  "browser_action": {
    "default_title": "Toggle Corvus",
    "default_icon": "icons/corvus.svg"
  },

  "icons": {
    "96": "icons/corvus.svg"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ]
}
